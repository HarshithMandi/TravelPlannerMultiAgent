SARVAM_API_KEY=
SARVAM_MODEL=sarvam-m
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENWEATHERMAP_API_KEY=
OPENTRIPMAP_API_KEY=
OPENROUTESERVICE_API_KEY=
REDIS_URL=

# LangSmith tracing (optional)
# Preferred keys:
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=trip-planner
LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
#
# Backward-compatible alias (this repo will also accept it):
LANGSMITH_APIKEY=
#
# (Alternative LangChain-style names, also supported):
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=trip-planner
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

CHROMA_PERSIST_DIR=./data/chroma
MEMORY_ENABLED=false
MEMORY_UPDATE_ENABLED=false
MEMORY_TOP_K=1
WORKER_LLM_ENABLED=false
AGENT_REASONING_LLM_ENABLED=false
DEFAULT_CURRENCY=INR
DEFAULT_COUNTRY=IN
LOG_LEVEL=INFO


